@{
    Layout = "_Adminlayout";
}

<main class="app-main">
    <div class="app-content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-6">
                    <h3 class="mb-0" style="color: var(--clr-terracotta);">Yönetici Paneli</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="app-content">
        <div class="container-fluid">
            <!-- İstatistik Kartları -->
            <div class="row">
                <div class="col-lg-3 col-6">
                    <div class="small-box text-white" style="background-color: var(--clr-terracotta); border-radius: 10px; box-shadow: 0 4px 15px rgba(11,29,105,0.3);">
                        <div class="inner p-4">
                            <h3>150</h3>
                            <p>Toplam Ürün</p>
                        </div>
                        <div class="small-box-icon" style="color: rgba(255,255,255,0.2);">
                            <i class="fas fa-shopping-bag fa-3x"></i>
                        </div>
                        <a href="/AdminUrun/UrunListele" class="small-box-footer text-white text-decoration-none d-block text-center p-2" style="background: rgba(0,0,0,0.1);">Detaylı İncele <i class="fas fa-arrow-circle-right"></i></a>
                    </div>
                </div>

                <div class="col-lg-3 col-6">
                    <div class="small-box text-white" style="background-color: var(--clr-gold); border-radius: 10px; box-shadow: 0 4px 15px rgba(204,161,107,0.3);">
                        <div class="inner p-4">
                            <h3>12</h3>
                            <p>Aktif Kategori</p>
                        </div>
                        <div class="small-box-icon" style="color: rgba(255,255,255,0.2);">
                            <i class="fas fa-layer-group fa-3x"></i>
                        </div>
                        <a href="/Admin/KategoriListele" class="small-box-footer text-white text-decoration-none d-block text-center p-2" style="background: rgba(0,0,0,0.1);">Detaylı İncele <i class="fas fa-arrow-circle-right"></i></a>
                    </div>
                </div>

                <div class="col-lg-3 col-6">
                    <div class="small-box text-white" style="background-color: #28a745; border-radius: 10px; box-shadow: 0 4px 15px rgba(40,167,69,0.3);">
                        <div class="inner p-4">
                            <h3>45,250 ₺</h3>
                            <p>Aylık Ciro</p>
                        </div>
                        <div class="small-box-icon" style="color: rgba(255,255,255,0.2);">
                            <i class="fas fa-chart-line fa-3x"></i>
                        </div>
                        <a href="#" class="small-box-footer text-white text-decoration-none d-block text-center p-2" style="background: rgba(0,0,0,0.1);">Detaylı İncele <i class="fas fa-arrow-circle-right"></i></a>
                    </div>
                </div>

                <div class="col-lg-3 col-6">
                    <div class="small-box text-white" style="background-color: #17a2b8; border-radius: 10px; box-shadow: 0 4px 15px rgba(23,162,184,0.3);">
                        <div class="inner p-4">
                            <h3>1,250</h3>
                            <p>Günlük Ziyaretçi</p>
                        </div>
                        <div class="small-box-icon" style="color: rgba(255,255,255,0.2);">
                            <i class="fas fa-users fa-3x"></i>
                        </div>
                        <a href="#" class="small-box-footer text-white text-decoration-none d-block text-center p-2" style="background: rgba(0,0,0,0.1);">Detaylı İncele <i class="fas fa-arrow-circle-right"></i></a>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-md-12">
                    <div class="card" style="border: none; box-shadow: 0 0 20px rgba(0,0,0,0.05); border-radius: 12px;">
                        <div class="card-header" style="background: var(--clr-terracotta); color: white; border-radius: 12px 12px 0 0;">
                            <h3 class="card-title mb-0"><i class="fas fa-chart-bar me-2"></i> Satış Analizi</h3>
                        </div>
                        <div class="card-body">
                            <canvas id="salesChart" style="min-height: 300px; height: 300px; max-height: 300px; max-width: 100%;"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function () {
            var ctx = document.getElementById('salesChart').getContext('2d');
            var salesChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Oca', 'Şub', 'Mar', 'Nis', 'May', 'Haz', 'Tem'],
                    datasets: [{
                        label: 'Aylık Satış (₺)',
                        data: [12000, 19000, 15000, 25000, 22000, 30000, 45250],
                        backgroundColor: '#cca16b',
                        borderColor: '#cca16b',
                        borderWidth: 1,
                        borderRadius: 5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });
        });
    </script>
}