@model TanıtımWebSitesi.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Güvenli Ödeme";
    var cart = Context.Session.Get<List<TanıtımWebSitesi.Models.CartItem>>("Cart") ?? new List<TanıtımWebSitesi.Models.CartItem>();
    decimal total = cart.Sum(x => x.Fiyat * x.Adet);
}

<div class="container py-5 mt-5">
    <h2 class="geo-section-title mb-4">Güvenli Ödeme</h2>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h4 class="mb-4">Teslimat ve Ödeme Bilgileri</h4>
                    
                    <form asp-action="Checkout" method="post">
                        
                        <h5 class="mb-3 text-muted">Kişisel Bilgiler</h5>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Ad Soyad</label>
                                <input asp-for="AdSoyad" class="form-control" placeholder="Örn: Ayşe Yılmaz">
                                <span asp-validation-for="AdSoyad" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Telefon</label>
                                <input asp-for="Telefon" class="form-control" placeholder="05XX XXX XX XX">
                                <span asp-validation-for="Telefon" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Açık Adres</label>
                                <textarea asp-for="Adres" class="form-control" rows="3" placeholder="Mahalle, Sokak, İlçe, İl"></textarea>
                                <span asp-validation-for="Adres" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4">

                        <h5 class="mb-3 text-muted">Kart Bilgileri</h5>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Kart Üzerindeki İsim</label>
                                <input asp-for="KartIsim" class="form-control">
                                <span asp-validation-for="KartIsim" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Kart Numarası</label>
                                <input asp-for="KartNumara" class="form-control" placeholder="1111222233334444" maxlength="16">
                                <span asp-validation-for="KartNumara" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Son Kullanma (Ay/Yıl)</label>
                                <input asp-for="SonKullanma" class="form-control" placeholder="12/25">
                                <span asp-validation-for="SonKullanma" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">CVV</label>
                                <input asp-for="Cvv" class="form-control" placeholder="123" maxlength="3">
                                <span asp-validation-for="Cvv" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mt-5">
                            <button type="submit" class="btn-geo w-100 py-3" style="font-size: 1.1rem;">Siparişi Onayla ve Öde (@total.ToString("N2") TL)</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Sepetinizdeki Ürünler</h5>
                    
                    @foreach(var item in cart)
                    {
                        <div class="d-flex mb-3 align-items-center">
                            <img src="@item.ResimUrl" alt="Ürün" style="width: 50px; height: 70px; object-fit: cover;" class="me-3 rounded">
                            <div class="flex-grow-1">
                                <h6 class="mb-0" style="font-size: 0.9rem;">@item.UrunAdi</h6>
                                <small class="text-muted">Adet: @item.Adet</small>
                            </div>
                            <div class="fw-bold">@((item.Fiyat * item.Adet).ToString("N2")) TL</div>
                        </div>
                    }

                    <hr class="my-4">
                    
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Ara Toplam:</span>
                        <span class="fw-bold">@total.ToString("N2") TL</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Kargo:</span>
                        <span class="text-success fw-bold">Ücretsiz</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <h5 class="fw-bold mb-0">Toplam:</h5>
                        <h4 class="fw-bold text-danger mb-0">@total.ToString("N2") TL</h4>
                    </div>
                </div>
            </div>
            
            <div class="text-center mt-3 text-muted small">
                <i class="fa-solid fa-lock text-success me-1"></i> 256-bit SSL Güvenli Ödeme
            </div>
        </div>
    </div>
</div>
