@model List<TanıtımWebSitesi.Models.CartItem>

@{
    ViewData["Title"] = "Alışveriş Sepeti";
    decimal total = Model.Sum(x => x.Fiyat * x.Adet);
}

<div class="container py-5 mt-5">
    <h2 class="geo-section-title">Alışveriş Sepetim</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info py-4 text-center mt-4">
            <h5 class="mb-3">Sepetinizde henüz ürün bulunmuyor.</h5>
            <a href="/Home/Index" class="btn-geo">Alışverişe Başla</a>
        </div>
    }
    else
    {
        <div class="row mt-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-0">
                        <table class="table mb-0 align-middle">
                            <thead class="bg-light">
                                <tr>
                                    <th scope="col" class="px-4 py-3 border-0">Ürün</th>
                                    <th scope="col" class="py-3 border-0">Fiyat</th>
                                    <th scope="col" class="py-3 border-0 text-center">Adet</th>
                                    <th scope="col" class="py-3 border-0 text-end pe-4">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="px-4 py-3 border-bottom">
                                            <div class="d-flex align-items-center">
                                                <img src="@item.ResimUrl" alt="@item.UrunAdi" style="width: 60px; height: 80px; object-fit: cover;" class="me-3 border">
                                                <h6 class="mb-0">@item.UrunAdi</h6>
                                            </div>
                                        </td>
                                        <td class="py-3 border-bottom">@item.Fiyat.ToString("N2") TL</td>
                                        <td class="py-3 border-bottom text-center">
                                            <span class="badge bg-dark px-3 py-2">@item.Adet</span>
                                        </td>
                                        <td class="py-3 border-bottom text-end pe-4">
                                            <form asp-action="RemoveFromCart" asp-controller="Cart" method="post">
                                                <input type="hidden" name="id" value="@item.UrunId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i> Kaldır</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm bg-light">
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-4">Sipariş Özeti</h4>
                        
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Ara Toplam:</span>
                            <span class="fw-bold">@total.ToString("N2") TL</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Kargo:</span>
                            <span class="text-success fw-bold">Ücretsiz</span>
                        </div>
                        
                        <hr class="my-4">
                        
                        <div class="d-flex justify-content-between mb-4">
                            <h5 class="fw-bold mb-0">Genel Toplam:</h5>
                            <h4 class="fw-bold text-danger mb-0">@total.ToString("N2") TL</h4>
                        </div>
                        
                        <a href="/Cart/Checkout" class="btn-geo w-100 text-center d-block">Alışverişi Tamamla <i class="fa-solid fa-arrow-right ms-2"></i></a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
