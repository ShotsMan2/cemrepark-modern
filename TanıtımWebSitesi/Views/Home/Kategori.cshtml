@model List<TanıtımWebSitesi.Models.Admin.Aurun>
@{
    ViewData["Title"] = ViewBag.KategoriAdi;
}

<div class="container py-5 mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="geo-section-title mb-0">@(string.IsNullOrEmpty(ViewBag.KategoriAdi) ? "Tüm Ürünler" : ViewBag.KategoriAdi)</h2>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var urun in Model)
            {
                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="geo-card h-100">
                        <a href="/Home/urundetay/@urun.Id" class="d-block text-decoration-none">
                            <div class="geo-card-img position-relative">
                                <img src="@urun.Gorsel" alt="@urun.Ad" onerror="this.src='/assets/siteimg/hero_hijab_tunic.png'">
                            </div>
                        </a>
                        <div class="geo-card-body text-center d-flex flex-column p-3">
                            <a href="/Home/urundetay/@urun.Id" class="text-decoration-none text-dark d-block" style="min-height: 48px; display: flex; align-items: center; justify-content: center;">
                                <h5 class="mb-2" style="font-size: 1.05rem; font-weight: 600; line-height: 1.4;">@urun.Ad</h5>
                            </a>
                            <div class="geo-price mb-3" style="color: #E11C8E; font-size: 1.1rem; font-weight: 700;">@urun.Fiyat.ToString("N2") TL</div>
                            
                            <div class="mt-auto d-flex justify-content-center gap-2">
                                <button onclick="addToCart(this, @urun.Id, '@urun.Ad.Replace("'", "\\'")', @urun.Fiyat.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture), '@urun.Gorsel')" class="btn-geo w-75 py-2" style="font-size: 0.85rem; transition: all 0.3s;">
                                    Sepete Ekle
                                </button>
                                <button onclick="addToFavorites(this, @urun.Id, '@urun.Ad.Replace("'", "\\'")', @urun.Fiyat.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture), '@urun.Gorsel')" class="btn-geo-outline py-2 px-3" style="transition: all 0.3s;">
                                    <i class="fa-regular fa-heart"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted fs-5">Bu kategoriye ait ürün bulunamadı.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function addToCart(btn, id, name, price, image) {
            let originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-check"></i> Eklendi';
            btn.classList.add('bg-success', 'text-white', 'border-success');
            
            $.post('/Cart/AddToCart', { id: id, name: name, price: price, image: image }, function (data) {
                if (data.success) {
                    if ($('#cart-count').length) {
                        $('#cart-count').text(data.cartCount);
                    }
                    // 2 saniye sonra butonu eski haline getir
                    setTimeout(() => {
                        btn.innerHTML = originalHtml;
                        btn.classList.remove('bg-success', 'text-white', 'border-success');
                    }, 2000);
                }
            });
        }

        function addToFavorites(btn, id, name, price, image) {
            // İkonu katı (dolu) kırmızı kalbe çevir
            btn.innerHTML = '<i class="fa-solid fa-heart text-danger"></i>';
            btn.classList.add('border-danger');
            
            $.post('/Cart/AddToFavorites', { id: id, name: name, price: price, image: image }, function (data) {
                // Arka planda favorilere eklendi
            });
        }
    </script>
}
