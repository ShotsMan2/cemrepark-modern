@model TanıtımWebSitesi.Models.Admin.Aurun
@{
    ViewData["Title"] = Model.Ad;
}

<div class="container py-5 mt-5" data-aos="fade-up" data-aos-duration="1000">
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="geo-card h-100 p-3">
                <img src="@Model.Gorsel" class="img-fluid rounded" alt="@Model.Ad" onerror="this.src='/assets/siteimg/hero_hijab_tunic.png'">
            </div>
        </div>
        <div class="col-md-6">
            <h3 class="geo-section-title" style="margin-bottom: 1rem;">@Model.Ad</h3>
            <h4 class="geo-price mb-4">
                @Model.Fiyat.ToString("N2") TL
            </h4>
            <hr />
            <div class="form-floating mb-3">
                <select class="form-select" id="bedenSelect" aria-label="Beden Seçimi">
                    <option selected>Seçiniz</option>
                    <option value="1">38</option>
                    <option value="2">40</option>
                    <option value="3">42</option>
                    <option value="4">44</option>
                    <option value="5">46</option>
                    <option value="6">48</option>
                </select>
                <label for="bedenSelect">Beden</label>
            </div>
            <div class="form-floating mb-4">
                <select class="form-select" id="renkSelect" aria-label="Renk Seçimi">
                    <option selected>Seçiniz</option>
                    <option value="1">Siyah</option>
                    <option value="2">Ekru</option>
                    <option value="3">Taba</option>
                </select>
                <label for="renkSelect">Renk</label>
            </div>
            <hr />

            <div class="d-flex gap-3 mb-4">
                <button onclick="addToCart(this, @Model.Id, '@Model.Ad.Replace("'", "\\'")', @Model.Fiyat.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture), '@Model.Gorsel')" class="btn-geo py-3 px-5 fs-5 flex-grow-1" style="transition: all 0.3s;">
                    Sepete Ekle
                </button>
                <button onclick="addToFavorites(this, @Model.Id, '@Model.Ad.Replace("'", "\\'")', @Model.Fiyat.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture), '@Model.Gorsel')" class="btn-geo-outline py-3 px-4" style="transition: all 0.3s;">
                    <i class="fa-regular fa-heart fs-4"></i>
                </button>
            </div>
            <hr />
            <h5>Ürün Açıklaması</h5>
            <p class="text-muted">
                @Model.Ad - 
                Cemre Park kalitesiyle özenle üretilmiştir. 
                Tam kalıp, kullandığınız bedeni tercih edebilirsiniz. 
                Kumaş dokusu ve rahatlığıyla gün boyu şıklığınızı tamamlar. 
                Güvenli ödeme ve hızlı kargo ile hemen sahip olun.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addToCart(btn, id, name, price, image) {
            let originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Ekleniyor...';
            
            $.post('/Cart/AddToCart', { id: id, name: name, price: price, image: image }, function (data) {
                if (data.success) {
                    if ($('#cart-count').length) {
                        $('#cart-count').text(data.cartCount);
                    }
                    btn.innerHTML = '<i class="fa-solid fa-check"></i> Sepete Eklendi';
                    
                    Toast.fire({
                        icon: 'success',
                        title: 'Sepete Eklendi!',
                        text: name + ' sepetinize başarıyla eklendi.',
                        background: 'var(--clr-terracotta)',
                        color: '#fff',
                        iconColor: '#fff'
                    });

                    setTimeout(() => {
                        btn.innerHTML = originalHtml;
                    }, 2000);
                }
            });
        }

        function addToFavorites(btn, id, name, price, image) {
            btn.innerHTML = '<i class="fa-solid fa-heart text-danger fs-4"></i>';
            btn.classList.add('border-danger');
            
            $.post('/Cart/AddToFavorites', { id: id, name: name, price: price, image: image }, function (data) {
                Toast.fire({
                    icon: 'success',
                    title: 'Favorilere Eklendi!',
                    text: name + ' favorilerinize kaydedildi.',
                    background: '#fff',
                    color: 'var(--clr-terracotta)',
                    iconColor: '#ff4e88'
                });
            });
        }
    </script>
}
