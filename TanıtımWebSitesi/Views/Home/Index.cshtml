@{
    ViewData["Title"] = "Ana Sayfa";
}

<!-- GEOMETRİK HERO SECTION -->
<section class="geo-hero" data-aos="fade-in" data-aos-duration="1200">
    <div class="container geo-hero-content">
        <div class="row align-items-center">
            <div class="col-lg-6" data-aos="fade-right" data-aos-delay="200">
                <h1 style="color: var(--clr-terracotta);">Tarzınızı Yansıtın! 💫</h1>
                <p class="lead mb-4">CemrePark ile en trend tesettür takımlar, elbiseler ve tunikleri keşfedin. Şıklığınızla fark yaratın!</p>
                <a href="https://shopier.com/CEMREPARKK" class="btn-geo" target="_blank">Shopier Mağazamız</a>
                <a href="https://wa.me/905541698909" class="btn-geo-outline ms-2" target="_blank">WhatsApp Sipariş</a>
            </div>
            <div class="col-lg-6 mt-5 mt-lg-0">
                <div class="geo-image-wrapper">
                    <img src="/assets/siteimg/yeni1.jpg" alt="Yeni Sezon Tesettür Takım" class="img-fluid">
                </div>
            </div>
        </div>
    </div>
</section>

